{
  "name": "personal-portfolio-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-deployment-profile.mjs dev --profile=github-pages --context=preview",
    "build": "node scripts/run-deployment-profile.mjs build --profile=github-pages --context=production",
    "build:deploy": "node scripts/run-deployment-profile.mjs build",
    "build:validate:github-pages": "node scripts/run-deployment-profile.mjs build-and-validate --profile=github-pages --context=production",
    "build:validate:custom-domain": "node scripts/run-deployment-profile.mjs build-and-validate --profile=custom-domain --context=production",
    "build:validate:preview": "node scripts/run-deployment-profile.mjs build-and-validate --profile=github-pages --context=preview",
    "build:validate:custom-domain-preview": "node scripts/run-deployment-profile.mjs build-and-validate --profile=custom-domain --context=preview",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs",
    "validate:deploy": "node scripts/run-deployment-profile.mjs validate"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.7",
    "next": "^15.5.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.5.7",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.6",
    "@tailwindcss/postcss": "^4.1.6",
    "typescript": "^5.8.3"
  }
}
